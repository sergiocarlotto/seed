# Copie este arquivo para `.env` e ajuste os valores.
# O `.env` NAO e versionado (contem segredos). Este `.env.example` sim.

# ---------- Banco de dados (PostgreSQL) ----------
POSTGRES_USER=seed
POSTGRES_PASSWORD=troque-esta-senha-no-seu-env-local
POSTGRES_DB=seed

# ---------- Backend (ASP.NET Core) ----------
# Development | Production
ASPNETCORE_ENVIRONMENT=Development

# ---------- Reverse proxy (Caddy) ----------
# Dev:  :80                (http://localhost)
# Prod: seu-dominio.com    (Caddy emite TLS automaticamente)
SITE_ADDRESS=:80

# ---------- Frontend (Next.js) ----------
# URL interna usada por Server Components para chamar a API (server-side).
# Docker: http://api:8080  |  dev híbrido: http://localhost:8080 (default no código)
INTERNAL_API_URL=http://localhost:8080
